# ---------------------------------------------------------------------------
# SupportDiag AI — environment configuration
# Copy to `.env` for local dev; set these in Hostinger hPanel for production.
# Never commit real secrets.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_APP_NAME="SupportDiag AI"
NEXT_PUBLIC_APP_URL="https://supportdiag.yourdomain.com"

# --- Database (Hostinger MySQL / MariaDB) ---
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME"
# PostgreSQL is optionally supported by switching prisma/schema.prisma to
# provider "postgresql" and regenerating migrations (see README).

# --- Auth ---
# 32+ char random secret used to sign session JWTs (openssl rand -base64 32)
NEXTAUTH_SECRET="change_me"
NEXTAUTH_URL="https://supportdiag.yourdomain.com"

# --- Google sign-in (optional; leave blank to hide the button) ---
# OAuth client (Web application) with redirect URI:
#   <NEXTAUTH_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Storage (Hostinger local disk by default) ---
# Drivers: local | supabase | s3 (s3 is a future placeholder)
# Local paths are relative to the app root and must be OUTSIDE the public web
# root. Files are only served through authenticated API endpoints.
STORAGE_DRIVER="local"
UPLOAD_DIR="./storage/uploads"
EXTRACTED_DIR="./storage/extracted"
REPORT_DIR="./storage/reports"

# Supabase driver (only if STORAGE_DRIVER=supabase)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="support-files"

# --- AI (OpenAI-compatible) ---
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4.1-mini"
ENABLE_AI="true"

# --- Limits & retention (Hostinger Cloud friendly defaults) ---
MAX_UPLOAD_SIZE_MB="100"
MAX_EXTRACTED_SIZE_MB="500"
MAX_EXTRACTED_FILES="10000"
RETENTION_DAYS="7"
# Jobs processed per cron tick (keep 1 on shared/cloud hosting)
CRON_BATCH_SIZE="1"

# --- Cron protection ---
# Required by /api/cron/* endpoints (Authorization: Bearer <CRON_SECRET> or ?key=)
CRON_SECRET="change_me"

# --- Cross-app SSO from TheCyberAdviser (optional) ---
# Shared HS256 secret; MUST match the site's SUPPORTDIAG_SSO_SECRET. When set,
# /api/auth/sso accepts short-lived tickets minted by the site so its users sign
# in without a separate SupportDiag account. Leave blank to disable SSO.
SUPPORTDIAG_SSO_SECRET=""
SUPPORTDIAG_SSO_ISSUER="thecyberadviser"

# --- Redaction policy defaults (secrets are ALWAYS redacted) ---
REDACT_SERIAL_NUMBERS="true"
REDACT_IP_ADDRESSES="true"
REDACT_EMAILS="true"
REDACT_CERTIFICATES="true"
REDACT_SECRETS="true"
