# ---------------------------------------------------------------------------
# FirewallLens AI — environment configuration
# Copy this file to `.env` (local) and set the values in Hostinger hPanel for
# production. Never commit real secrets.
# ---------------------------------------------------------------------------

# Public base URL of the deployed app
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# --- Database (Neon / Supabase Postgres) ---
# Pooled connection string used by the app at runtime
DATABASE_URL=
# Direct (non-pooled) connection string used by Prisma migrations
DIRECT_URL=

# --- Auth ---
# 32+ char random secret used to sign session JWTs (openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://yourdomain.com

# --- Google sign-in (optional) ---
# Create an OAuth 2.0 Client ID (type: Web application) in Google Cloud Console
# and add <NEXTAUTH_URL>/api/auth/google/callback as an authorized redirect URI.
# Leave blank to hide the "Continue with Google" button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Storage ---
# supabase | r2 | local
STORAGE_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=support-files

# Cloudflare R2 (only needed if STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=support-files

# --- AI (OpenAI-compatible) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
ENABLE_AI=true

# --- Limits & retention ---
MAX_UPLOAD_SIZE_MB=100
MAX_EXTRACTED_SIZE_MB=500
MAX_EXTRACTED_FILES=10000
RETENTION_DAYS=7

# --- Cron protection ---
# Shared secret required by /api/cron/* endpoints (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=
