// SupportDiag AI — Prisma schema
// Primary target: MySQL / MariaDB (Hostinger hPanel databases).
// PostgreSQL remains possible by switching the provider and regenerating
// migrations (see README "Database options").

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ENGINEER
  VIEWER
}

enum UploadStatus {
  UPLOADED
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  DELETED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFORMATIONAL
}

enum FindingStatus {
  OPEN
  VALID
  FALSE_POSITIVE
  NEEDS_REVIEW
}

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  passwordHash String? // null for OAuth-only accounts
  authProvider String  @default("credentials") // credentials | google
  googleId     String? @unique // Google `sub` claim
  avatarUrl    String?
  role         Role    @default(ENGINEER)
  organizationId String?
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  uploads        Upload[]
  conversations  AIConversation[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId])
}

model Organization {
  id            String   @id @default(cuid())
  name          String
  plan          String   @default("startup")
  retentionDays Int      @default(7)
  users         User[]
  uploads       Upload[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Upload {
  id                 String        @id @default(cuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId     String?
  organization       Organization? @relation(fields: [organizationId], references: [id])
  originalFilename   String
  fileHash           String
  fileSize           Int
  archiveStoragePath String
  status             UploadStatus  @default(UPLOADED)
  supportFileType    String? // tgz | tar.gz | tar | zip | log | txt | json | xml
  redactByDefault    Boolean       @default(true)
  healthScore        Int? // cached score for dashboard aggregates

  // Multi-vendor detection
  selectedVendor      String? // user hint (vendor id) or null/auto
  selectedProduct     String? // user hint (product id) or null/auto
  detectedVendor      String? // resolved vendor id
  detectedProduct     String? // resolved product id
  detectionConfidence Int? // 0-100

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  job              AnalysisJob?
  device           Device?
  assets           Asset[]
  extractedFiles   ExtractedFile[]
  artifacts        ParsedArtifact[]
  findings         Finding[]
  conversations    AIConversation[]
  reports          Report[]
  knownIssueMatches KnownIssueMatch[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([detectedVendor])
}

model AnalysisJob {
  id           String    @id @default(cuid())
  uploadId     String    @unique
  upload       Upload    @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  status       JobStatus @default(PENDING)
  currentStep  String    @default("queued")
  progress     Int       @default(0)
  errorMessage String? @db.Text
  attempts     Int       @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
}

model Device {
  id               String   @id @default(cuid())
  uploadId         String   @unique
  upload           Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  hostname         String?
  serialNumber     String?
  model            String?
  panosVersion     String?
  deviceType       String?
  uptime           String?
  haStatus         String?
  panoramaManaged  Boolean  @default(false)
  panoramaServer   String?
  lastCommitStatus String?
  createdAt        DateTime @default(now())
}

// Normalized multi-vendor asset (device/tenant/environment) derived from a bundle.
model Asset {
  id           String    @id @default(cuid())
  uploadId     String
  upload       Upload    @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  vendor       String?
  product      String?
  hostname     String?
  serialNumber String?
  version      String?
  model        String?
  role         String?
  metadataJson Json?
  findings     Finding[]
  createdAt    DateTime  @default(now())

  @@index([uploadId])
}

model ExtractedFile {
  id        String   @id @default(cuid())
  uploadId  String
  upload    Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  path      String
  fileType  String?
  size      Int
  hash      String?
  content   String? @db.LongText // only stored for indexed text files
  indexed   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([uploadId])
  @@index([uploadId, indexed])
}

model ParsedArtifact {
  id             String   @id @default(cuid())
  uploadId       String
  upload         Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  vendor         String?
  product        String?
  parserName     String
  artifactType   String
  dataJson       Json
  sourceFilePath String?
  createdAt      DateTime @default(now())

  @@index([uploadId])
  @@index([uploadId, artifactType])
}

model Finding {
  id             String        @id @default(cuid())
  uploadId       String
  upload         Upload        @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  assetId        String?
  asset          Asset?        @relation(fields: [assetId], references: [id], onDelete: SetNull)
  vendor         String?
  product        String?
  ruleId         String
  severity       Severity
  category       String
  title          String
  description    String @db.Text
  impact         String @db.Text
  recommendation String @db.Text
  confidence     Int // 0-100
  evidenceJson   Json
  status         FindingStatus @default(OPEN)
  analystNote    String? @db.Text
  createdAt      DateTime      @default(now())

  @@index([uploadId])
  @@index([uploadId, severity])
  @@index([vendor])
}

model AIConversation {
  id           String   @id @default(cuid())
  uploadId     String
  upload       Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question     String @db.Text
  answer       String @db.Text
  evidenceJson Json
  createdAt    DateTime @default(now())

  @@index([uploadId])
}

model Report {
  id         String   @id @default(cuid())
  uploadId   String
  upload     Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  reportType String // executive | technical | customer | internal (+ format)
  format     String   @default("html") // html | markdown
  content    String @db.LongText
  redacted   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([uploadId])
}

// Registry of vendor/product parser modules (metadata for the Vendor Parsers page).
model VendorParser {
  id         String   @id @default(cuid())
  vendor     String
  product    String
  parserName String
  enabled    Boolean  @default(true)
  maturity   String   @default("low") // high | medium | low
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([vendor, product, parserName])
}

// Registry of diagnostic rules (metadata + enable/disable toggles).
model DiagnosticRule {
  id        String   @id @default(cuid())
  vendor    String
  product   String
  ruleId    String   @unique
  category  String
  severity  String
  title     String
  enabled   Boolean  @default(true)
  maturity  String   @default("medium")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendor, product])
}

// Small key-value state store (cron heartbeats, operational flags).
model SystemState {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// Version-aware known-issue signature (publicly documented issue families).
model KnownIssue {
  id                    String            @id @default(cuid())
  vendor                String
  product               String
  issueId               String            @unique
  title                 String
  minAffectedVersion    String?
  maxAffectedVersion    String?
  fixedVersion          String?
  symptomPatternsJson   Json
  requiredEvidenceJson  Json?
  exclusionCriteriaJson Json?
  sourceReference       String            @db.Text
  remediation           String            @db.Text
  enabled               Boolean           @default(true)
  matches               KnownIssueMatch[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([vendor, product])
}

// A known-issue candidate detected in a specific case (upload).
model KnownIssueMatch {
  id           String     @id @default(cuid())
  uploadId     String
  upload       Upload     @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  knownIssueId String
  knownIssue   KnownIssue @relation(fields: [knownIssueId], references: [id], onDelete: Cascade)
  matchType    String // Exact Match | Strong Candidate | Possible Match
  confidence   Int
  evidenceJson Json
  explanation  String     @db.Text
  createdAt    DateTime   @default(now())

  @@index([uploadId])
}
