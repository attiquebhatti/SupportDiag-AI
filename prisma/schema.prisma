// FirewallLens AI — Prisma schema
// PostgreSQL (Neon / Supabase). Uses a pooled DATABASE_URL at runtime and a
// DIRECT_URL for migrations, matching the Hostinger Cloud deployment model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  ENGINEER
  VIEWER
}

enum UploadStatus {
  UPLOADED
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  DELETED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFORMATIONAL
}

enum FindingStatus {
  OPEN
  VALID
  FALSE_POSITIVE
  NEEDS_REVIEW
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  passwordHash   String
  role           Role            @default(ENGINEER)
  organizationId String?
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  uploads        Upload[]
  conversations  AIConversation[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId])
}

model Organization {
  id            String   @id @default(cuid())
  name          String
  plan          String   @default("startup")
  retentionDays Int      @default(7)
  users         User[]
  uploads       Upload[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Upload {
  id                 String        @id @default(cuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId     String?
  organization       Organization? @relation(fields: [organizationId], references: [id])
  originalFilename   String
  fileHash           String
  fileSize           Int
  archiveStoragePath String
  status             UploadStatus  @default(UPLOADED)
  supportFileType    String? // tgz | tar.gz | tar | zip
  redactByDefault    Boolean       @default(true)
  healthScore        Int? // cached score for dashboard aggregates
  createdAt          DateTime      @default(now())
  deletedAt          DateTime?

  job           AnalysisJob?
  device        Device?
  extractedFiles ExtractedFile[]
  artifacts     ParsedArtifact[]
  findings      Finding[]
  conversations AIConversation[]
  reports       Report[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model AnalysisJob {
  id           String    @id @default(cuid())
  uploadId     String    @unique
  upload       Upload    @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  status       JobStatus @default(PENDING)
  currentStep  String    @default("queued")
  progress     Int       @default(0)
  errorMessage String?
  attempts     Int       @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
}

model Device {
  id               String   @id @default(cuid())
  uploadId         String   @unique
  upload           Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  hostname         String?
  serialNumber     String?
  model            String?
  panosVersion     String?
  deviceType       String?
  uptime           String?
  haStatus         String?
  panoramaManaged  Boolean  @default(false)
  panoramaServer   String?
  lastCommitStatus String?
  createdAt        DateTime @default(now())
}

model ExtractedFile {
  id        String   @id @default(cuid())
  uploadId  String
  upload    Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  path      String
  fileType  String?
  size      Int
  hash      String?
  content   String? // only stored for indexed text files
  indexed   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([uploadId])
  @@index([uploadId, indexed])
}

model ParsedArtifact {
  id             String   @id @default(cuid())
  uploadId       String
  upload         Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  parserName     String
  artifactType   String
  dataJson       Json
  sourceFilePath String?
  createdAt      DateTime @default(now())

  @@index([uploadId])
  @@index([uploadId, artifactType])
}

model Finding {
  id             String        @id @default(cuid())
  uploadId       String
  upload         Upload        @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  ruleId         String
  severity       Severity
  category       String
  title          String
  description    String
  impact         String
  recommendation String
  confidence     Int // 0-100
  evidenceJson   Json
  status         FindingStatus @default(OPEN)
  createdAt      DateTime      @default(now())

  @@index([uploadId])
  @@index([uploadId, severity])
}

model AIConversation {
  id           String   @id @default(cuid())
  uploadId     String
  upload       Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question     String
  answer       String
  evidenceJson Json
  createdAt    DateTime @default(now())

  @@index([uploadId])
}

model Report {
  id         String   @id @default(cuid())
  uploadId   String
  upload     Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  reportType String // html | markdown
  content    String
  redacted   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([uploadId])
}
